{
  "name": "cloud-kitchen-startup-mode",
  "version": "1.0.0",
  "private": true,
  "description": "Responsive full-stack cloud kitchen app with connected frontend and backend.",
  "main": "server.js",
  "dependencies": {
    "pg": "^8.13.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "start:db": "node server.postgres.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "admin:dev": "vite --config admin-app/vite.config.js",
    "admin:build": "vite build --config admin-app/vite.config.js",
    "admin:preview": "vite preview --config admin-app/vite.config.js",
    "customer:dev": "vite --config customer-app/vite.config.js",
    "customer:build": "vite build --config customer-app/vite.config.js",
    "customer:preview": "vite preview --config customer-app/vite.config.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.3"
  }
}
